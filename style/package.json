{
  "name": "ui",
  "version": "0.1.0",
  "description": "Tailwind & DaisyUI to compile app.css to static/uk-retejo.css",
  "scripts": {
    "watch:css": "npx @tailwindcss/cli -i app.css -o ../backend/config/static/uk-retejo.css --watch=always -m",
    "build:css": "npx @tailwindcss/cli -i app.css -o ../backend/config/static/uk-retejo.css",
    "watch:evente": "npx @tailwindcss/cli -i evente.css -o ../backend/evente/static/evente/assets/css/main.css --watch=always -m",
    "build:evente": "npx @tailwindcss/cli -i evente.css -o ../backend/evente/static/evente/assets/css/main.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edukado-interreto/uk-retejo.git"
  },
  "keywords": [
    "tailwind",
    "daisyui",
    "css"
  ],
  "author": "Baptiste Darthenay",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/edukado-interreto/uk-retejo/issues"
  },
  "homepage": "https://github.com/edukado-interreto/uk-retejo#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@tailwindcss/typography": "^0.5.18"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "photoswipe": "^5.4.4"
  }
}
